<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <RootNamespace>Lumen.Backoffice</RootNamespace>
    <AssemblyName>Lumen.Backoffice</AssemblyName>
    <UserSecretsId>85b3077f-d7a9-4beb-8cf6-cd486aea60e3</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\SharedKernel\Lumen.SharedKernel\Lumen.SharedKernel.csproj" />
    <ProjectReference Include="..\..\Jobs\Lumen.Jobs\Lumen.Jobs.csproj" />
    <ProjectReference Include="..\..\Lumen.Infrastructure\Lumen.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Modules\Identity\Lumen.Modules.Identity\Lumen.Modules.Identity.csproj" />
    <ProjectReference Include="..\..\Lumen.Authorization\Lumen.Authorization.csproj" />
    <ProjectReference Include="..\..\Lumen.Authorization.Contracts\Lumen.Authorization.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Microsoft.AspNetCore.Authentication.Cookies is part of the Microsoft.AspNetCore.App
      shared framework — no PackageReference required for Sdk="Microsoft.NET.Sdk.Web".

      System.IdentityModel.Tokens.Jwt is used to decode the JWT returned by the Api
      and extract claims before signing the Backoffice cookie.
    -->
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
  </ItemGroup>

</Project>
