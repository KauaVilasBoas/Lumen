@model ProfilesController.EditProfileFormModel
@{
    ViewData["Title"] = "Edit profile";
    ViewData["Subtitle"] = "Update a role-like container";
    Layout = "_Layout";
}

<div class="content-wrap">
    <div class="card" style="max-width:560px;margin:0 auto;padding:26px">
        <div class="card-head" style="padding:0 0 18px">
            <div>
                <div class="eyebrow">Profiles</div>
                <h3 class="card-title">Edit profile</h3></div>
            <a asp-action="Index" class="btn sm ghost">Back</a>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="login-error" style="margin:0 0 16px"></div>
        }

        <form asp-action="Edit" method="post" class="login-form" style="margin:0">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden"/>
            <label class="field">
                <span class="field-label">Name</span>
                <div class="field-input"><input asp-for="Name" maxlength="128"/></div>
                <span asp-validation-for="Name" class="faint mono" style="font-size:11px;color:var(--danger)"></span>
            </label>
            <label class="field">
                <span class="field-label">Description</span>
                <div class="field-input"><input asp-for="Description" maxlength="512"/></div>
                <span asp-validation-for="Description" class="faint mono"
                      style="font-size:11px;color:var(--danger)"></span>
            </label>
            <button type="submit" class="btn primary"
                    style="align-self:flex-start;margin-top:6px">@await Html.PartialAsync("_Icon", "check") Save changes
            </button>
        </form>
    </div>
</div>
