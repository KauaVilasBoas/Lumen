{
  "_comment": "Copy this file to appsettings.json and replace all placeholders. NEVER commit real credentials.",

  "Mongo": {
    "_comment": "Set via env var Mongo__ConnectionString in production.",
    "ConnectionString": "<set via env or user-secrets>",
    "Database": "<set via env or user-secrets>"
  },

  "Jwt": {
    "_comment": "Secret must be at least 32 characters. Set via env var Jwt__Secret in production.",
    "Issuer": "AegisIdentity",
    "Audience": "AegisIdentity.Clients",
    "Secret": "<set via env or user-secrets>",
    "ExpirationMinutes": 15,
    "RefreshExpirationDays": 7
  },

  "Smtp": {
    "_comment": "Set host/user/pass via env vars Smtp__Host, Smtp__User, Smtp__Pass in production.",
    "Host": "<set via env or user-secrets>",
    "Port": 587,
    "User": "<set via env or user-secrets>",
    "Pass": "<set via env or user-secrets>",
    "From": "no-reply@yourdomain.com",
    "UseStartTls": true
  },

  "Hibp": {
    "UserAgent": "YourAppName/1.0 (contact@yourdomain.com)",
    "ApiBaseUrl": "https://api.pwnedpasswords.com"
  },

  "App": {
    "_comment": "Public base URL of this API — used to build links in outbound emails. No trailing slash.",
    "BaseUrl": "https://api.yourdomain.com"
  },

  "Cors": {
    "AllowedOrigins": [ "https://yourdomain.com" ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aegisidentity-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*"
}
