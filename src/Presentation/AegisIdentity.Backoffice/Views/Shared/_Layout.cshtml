<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — AegisIdentity Backoffice" : "AegisIdentity Backoffice")</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                AegisIdentity
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
                    <span class="text-light small">
                        Olá, <strong>@User.Identity.Name</strong>
                    </span>
                    <a class="nav-link text-light small" href="/hangfire" target="_blank" rel="noopener">
                        Jobs
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Sair</button>
                    </form>
                </div>
            }
            else
            {
                <div class="navbar-nav ms-auto">
                    <a class="nav-link text-light" asp-controller="Account" asp-action="Login">Entrar</a>
                </div>
            }
        </div>
    </nav>

    <main class="container pb-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmtlZp4vOrTpnhA/lVAGfdn3bh9P"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
