@model PermissionCatalogueViewModel
@{
    var all = Model.Groups.SelectMany(g => g.Permissions).ToList();
    var orphanCount = all.Count(p => p.IsOrphan);
}

<div class="lz-content-wrap">
    <div class="lz-stats-row">
        <div class="lz-stat lz-card">
            <div class="lz-stat-value lz-tnum">@all.Count</div>
            <div class="lz-stat-label">Discovered</div>
            <div class="lz-stat-sub lz-mono">across @Model.Groups.Count groups</div>
        </div>
        <div class="lz-stat lz-card">
            <div class="lz-stat-value lz-tnum">@(all.Count - orphanCount)</div>
            <div class="lz-stat-label">Active</div>
            <div class="lz-stat-sub lz-mono">reachable actions</div>
        </div>
        <div class="lz-stat lz-card">
            <div class="lz-stat-value lz-tnum">@orphanCount</div>
            <div class="lz-stat-label">Orphans</div>
            <div class="lz-stat-sub lz-mono">endpoint removed</div>
        </div>
    </div>

    <div class="lz-card lz-perm-catalogue">
        @foreach (var group in Model.Groups)
        {
            <div class="lz-perm-group">
                <div class="lz-perm-group-head">
                    <span class="lz-perm-group-name lz-mono">@group.GroupName</span>
                    <span class="lz-perm-group-count lz-mono">@group.Permissions.Count</span>
                </div>
                @foreach (var p in group.Permissions)
                {
                    var method = PermissionDisplayHelper.HttpMethod(p.Code);
                    <div class="lz-perm-item @(p.IsOrphan ? "orphan" : "")">
                        <span class="lz-method lz-mono"
                              style="color:@PermissionDisplayHelper.MethodCssColor(method);border-color:@PermissionDisplayHelper.MethodCssColor(method)">@method</span>
                        <div class="lz-perm-code-wrap">
                            <span class="lz-perm-code lz-mono">@p.Code</span>
                        </div>
                        <span class="lz-perm-name">@p.DisplayName</span>
                        @if (p.IsOrphan)
                        {
                            <span class="lz-badge lz-badge-warn">orphan</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
