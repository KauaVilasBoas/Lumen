{
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "aegisidentity_dev"
  },
  "Jwt": {
    "Issuer": "AegisIdentity",
    "Audience": "AegisIdentity.Clients",
    "Secret": "dev-only-secret-replace-in-prod-min-32-chars-xxxxxx",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 30
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "User": "",
    "Pass": "",
    "From": "no-reply@aegisidentity.local",
    "UseStartTls": false
  },
  "Hibp": {
    "UserAgent": "AegisIdentity/1.0-dev",
    "ApiBaseUrl": "https://api.pwnedpasswords.com"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
