@using AegisIdentity.Backoffice.Services
@model IReadOnlyList<AdminApiClient.ProfileItem>

@{
    ViewData["Title"] = "Perfis";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Perfis</h2>
    @if (await Html.HasPermissionAsync("Profiles", "Create"))
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">Novo Perfil</a>
    }
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Sistema</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var profile in Model)
            {
                <tr>
                    <td>@profile.Name</td>
                    <td class="text-muted">@profile.Description</td>
                    <td>
                        @if (profile.IsSystem)
                        {
                            <span class="badge bg-secondary">Sistema</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (await Html.HasPermissionAsync("Profiles", "Get"))
                        {
                            <a asp-action="Details" asp-route-id="@profile.Id"
                               class="btn btn-outline-info btn-sm me-1">Permissões</a>
                        }
                        @if (!profile.IsSystem && await Html.HasPermissionAsync("Profiles", "Update"))
                        {
                            <a asp-action="Edit" asp-route-id="@profile.Id"
                               class="btn btn-outline-secondary btn-sm me-1">Editar</a>
                        }
                        @if (!profile.IsSystem && await Html.HasPermissionAsync("Profiles", "Delete"))
                        {
                            <form asp-action="Delete" asp-route-id="@profile.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Remover perfil @profile.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Remover</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
