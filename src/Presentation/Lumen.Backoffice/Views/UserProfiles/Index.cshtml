@using Lumen.Backoffice.Services
@using Lumen.Backoffice.ViewModels
@model UserProfilesViewModel
@{
    ViewData["Title"] = "User profiles";
    ViewData["Subtitle"] = "Assignments for a single identity";
    Layout = "_Layout";
    var userId = Model.UserId;
    var availableProfiles = Model.AvailableProfiles;
}

<div class="content-wrap">
    <div class="reveal-region">
        <div class="card" style="overflow:hidden">
            <div class="reveal-tag" style="--lc:var(--dom);top:-11px;right:12px">
                <span class="reveal-tag-dot"></span><span class="reveal-tag-label mono">UserProfile join</span>
                <div class="reveal-tag-pop card">
                    <div class="reveal-tag-pop-layer mono" style="color:var(--dom)"><span class="sq" style="background:var(--dom)"></span>Domain</div>
                    <div class="reveal-tag-pop-body">Each assign/remove publishes <span class="code">UserPermissionsChanged</span>, invalidating this user's Redis cache entry.</div>
                </div>
            </div>

            <div class="mng-list-head">
                <span class="eyebrow">Assigned profiles</span>
                <span class="faint mono" style="font-size:11px">@userId</span>
            </div>

            @if (TempData["Error"] is string error)
            {
                <div class="login-error" style="margin:14px 20px">@error</div>
            }

            <div class="mng-list-body" style="padding:10px">
                @if (!Model.AssignedProfiles.Any())
                {
                    <div class="ud-empty mono" style="padding:18px">No profiles assigned.</div>
                }
                @foreach (var up in Model.AssignedProfiles)
                {
                    <div class="prow" style="--nc:@(up.IsSystem ? "#8b6dff" : "#4c8dff")">
                        <span class="prow-bar"></span>
                        <div class="prow-main">
                            <div class="prow-name">@up.ProfileName @(up.IsSystem ? Html.Raw("<span class=\"badge sys\" style=\"margin-left:7px\">SYSTEM</span>") : null)</div>
                        </div>
                        <div class="prow-count" style="padding-right:12px">
                            <form asp-action="Remove" asp-route-userId="@userId" asp-route-profileId="@up.ProfileId" method="post"
                                  onsubmit="return confirm('Remove @up.ProfileName from this user?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn sm danger">Remove</button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            @if (availableProfiles.Any() && await Html.HasPermissionAsync("UserProfiles", "Assign"))
            {
                <div style="padding:16px 20px;border-top:1px solid var(--line);display:flex;gap:10px;align-items:flex-end">
                    <form asp-action="Assign" asp-route-userId="@userId" method="post" style="display:flex;gap:10px;align-items:center">
                        @Html.AntiForgeryToken()
                        <select name="profileId" class="field-input mono" style="height:38px;min-width:240px;color:var(--text);padding:0 12px">
                            @foreach (var p in availableProfiles)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <button type="submit" class="btn sm primary">@await Html.PartialAsync("_Icon", "plus") Assign</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
