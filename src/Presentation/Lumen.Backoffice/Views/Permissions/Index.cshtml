@using Lumen.Backoffice.Services
@model IReadOnlyList<AdminApiClient.PermissionGroup>
@{
    ViewData["Title"] = "Permissions";
    ViewData["Subtitle"] = "Permission catalogue";
    Layout = "_Layout";

    var all = Model.SelectMany(g => g.Permissions).ToList();

    string RouteFor(string code)
    {
        var parts = code.Split('.');
        var ctrl = parts[0].ToLower();
        var action = parts.Length > 1 ? parts[1] : "";
        var b = "/api/" + ctrl;
        return action switch
        {
            "Get" or "Update" or "Delete" => b + "/{id}",
            "SetPermissions" => b + "/{id}/permissions",
            "Assign" or "Remove" => b + "/{userId}/{id}",
            "Ping" => b + "/ping", "Export" => b + "/export", _ => b
        };
    }
}

<div class="content-wrap">
    <div class="grid-4" style="margin-bottom:18px">
        <div class="stat card">
            <div class="stat-top"><span class="stat-ico"
                                        style="color:var(--pres);background:color-mix(in srgb,var(--pres) 14%,transparent)">@await Html.PartialAsync("_Icon", "key")</span>
            </div>
            <div class="stat-value tnum">@all.Count</div>
            <div class="stat-label">Total</div>
            <div class="stat-sub mono">across @Model.Count groups</div>
        </div>
        <div class="stat card">
            <div class="stat-top"><span class="stat-ico"
                                        style="color:var(--app);background:color-mix(in srgb,var(--app) 14%,transparent)">@await Html.PartialAsync("_Icon", "shieldKey")</span>
            </div>
            <div class="stat-value tnum">@Model.Count</div>
            <div class="stat-label">Groups</div>
            <div class="stat-sub mono">permission groups</div>
        </div>
        <div class="stat card">
            <div class="stat-top"><span class="stat-ico"
                                        style="color:var(--dom);background:color-mix(in srgb,var(--dom) 14%,transparent)">@await Html.PartialAsync("_Icon", "lock")</span>
            </div>
            <div class="stat-value tnum" style="font-size:24px">401 / 403</div>
            <div class="stat-label">Enforcement</div>
            <div class="stat-sub mono">dynamic policy provider</div>
        </div>
    </div>

    <div class="section-title" style="margin-top:22px"><h3>Permission catalogue</h3><span
            class="count mono">@all.Count</span><span class="line"></span></div>

    <div class="reveal-region">
        <div class="card perm-catalogue">
            @foreach (var group in Model)
            {
                <div class="perm-group">
                    <div class="perm-group-head"><span class="perm-group-name mono">@group.GroupName</span><span
                            class="perm-group-count mono">@group.Permissions.Count</span></div>
                    @foreach (var p in group.Permissions)
                    {
                        var m = PermissionDisplayHelper.HttpMethod(p.Code);
                        <div class="perm-item">
                            <span class="perm-method mono"
                                  style="color:@PermissionDisplayHelper.MethodCssColor(m);border-color:@PermissionDisplayHelper.MethodCssColor(m)">@m</span>
                            <div class="perm-code-wrap"><span class="perm-code mono">@p.Code</span><span
                                    class="perm-route mono">@RouteFor(p.Code)</span></div>
                            <span class="perm-name">@p.DisplayName</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
