<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Lumen.Modularity</PackageId>
    <Version>1.0.0</Version>
    <Authors>Kauã Vilas Boas</Authors>
    <Description>Building block reutilizável para monolitos modulares em ASP.NET Core: annotation [Module], interface IModule, auto-discovery de módulos por assembly scanning (AddModules/MapModules) e event bus in-process (IEventBus) para integration events entre módulos.</Description>
    <PackageTags>modular-monolith;modularity;module;event-bus;integration-events;cqrs;aspnetcore;dependency-injection</PackageTags>
    <PackageProjectUrl>https://github.com/KauaVilasBoas/Lumen</PackageProjectUrl>
    <RepositoryUrl>https://github.com/KauaVilasBoas/Lumen</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>

</Project>
