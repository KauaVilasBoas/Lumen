{
  "Mongo": {
    "ConnectionString": "REPLACE_ME",
    "Database": "aegisidentity"
  },
  "Jwt": {
    "Issuer": "AegisIdentity",
    "Audience": "AegisIdentity.Clients",
    "Secret": "REPLACE_ME",
    "ExpirationMinutes": 15,
    "RefreshExpirationDays": 7
  },
  "Smtp": {
    "Host": "REPLACE_ME",
    "Port": 587,
    "User": "REPLACE_ME",
    "Pass": "REPLACE_ME",
    "From": "no-reply@aegisidentity.local",
    "UseStartTls": true
  },
  "Hibp": {
    "UserAgent": "AegisIdentity/1.0 (contact@aegisidentity.local)",
    "ApiBaseUrl": "https://api.pwnedpasswords.com"
  },
  "Cors": {
    "AllowedOrigins": [ "REPLACE_ME" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aegisidentity-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
