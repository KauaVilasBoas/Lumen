@{
    ViewData["Title"] = "Início";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Painel Administrativo</h2>
        <p class="text-muted mb-0">Bem-vindo ao AegisIdentity Backoffice.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-5">
        @await Component.InvokeAsync("UserDetail")
    </div>
</div>

<div class="mt-4">
    @if (await Html.HasPermissionAsync("Admin", "Ping"))
    {
        <div class="alert alert-info">
            Você tem acesso à área administrativa de diagnóstico.
        </div>
    }

    <div asp-require-permission-controller="Admin" asp-require-permission-action="Ping"
         class="mt-2">
        <a class="btn btn-outline-secondary btn-sm" href="#">Diagnóstico (Admin.Ping)</a>
    </div>
</div>
