<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <RootNamespace>AegisIdentity.Backoffice</RootNamespace>
    <AssemblyName>AegisIdentity.Backoffice</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\SharedKernel\AegisIdentity.SharedKernel\AegisIdentity.SharedKernel.csproj" />
    <!--
      Jobs: provides HangfireDashboardAuthorizationFilter and AddAegisHangfire.
      The Backoffice acts as the dashboard UI host only — it calls AddAegisHangfire
      but does NOT call AddAegisHangfireServer to avoid a competing job-processor.
    -->
    <ProjectReference Include="..\..\Jobs\AegisIdentity.Jobs\AegisIdentity.Jobs.csproj" />
    <ProjectReference Include="..\..\AegisIdentity.Infrastructure\AegisIdentity.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Infrastructure\AegisIdentity.DataAccess\AegisIdentity.DataAccess.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Microsoft.AspNetCore.Authentication.Cookies is part of the Microsoft.AspNetCore.App
      shared framework — no PackageReference required for Sdk="Microsoft.NET.Sdk.Web".

      System.IdentityModel.Tokens.Jwt is used to decode the JWT returned by the Api
      and extract claims before signing the Backoffice cookie.
    -->
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
  </ItemGroup>

</Project>
