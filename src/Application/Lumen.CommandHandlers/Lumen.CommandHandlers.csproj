<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\..\Lumen.Domain\Lumen.Domain.csproj" />
    <ProjectReference Include="..\..\SharedKernel\Lumen.SharedKernel\Lumen.SharedKernel.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- MediatR — command handlers implement IRequestHandler<TRequest, TResponse> -->
    <PackageReference Include="MediatR" />
    <!-- Core validation — FluentValidation validators live next to the command they validate -->
    <PackageReference Include="FluentValidation" />
    <!-- Logging abstractions — ILogger<T> used in handlers, no concrete dependency -->
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <!-- DI registration extension methods -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

</Project>
